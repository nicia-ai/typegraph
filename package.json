{
  "name": "typegraph-monorepo",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.32.1",
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "test:types": "pnpm --filter @nicia-ai/typegraph test:types",
    "test:strict-local-consumers": "pnpm --filter @nicia-ai/typegraph test:strict-local-consumers",
    "test:api-report": "pnpm --filter @nicia-ai/typegraph test:api-report",
    "api-report:update": "pnpm --filter @nicia-ai/typegraph api-report:update",
    "test:unit": "turbo run test:unit",
    "test:property": "turbo run test:property",
    "test:postgres": "pnpm --filter @nicia-ai/typegraph test:postgres",
    "bench": "turbo run bench",
    "bench:maintenance": "pnpm --filter @nicia-ai/typegraph-benchmarks bench:maintenance",
    "bench:maintenance:postgres": "pnpm --filter @nicia-ai/typegraph-benchmarks bench:maintenance:postgres",
    "fix": "run-s fix:*",
    "fix:prettier": "prettier --write .",
    "fix:lint": "turbo run lint -- --fix",
    "fix:docs": "markdownlint-cli2 --fix \"**/*.md\" \"#node_modules\"",
    "prettier": "prettier --check .",
    "test:docs": "markdownlint-cli2 \"**/*.md\" \"#node_modules\"",
    "test:unused": "knip",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release": "turbo run build --filter='!@nicia-ai/typegraph-docs' && changeset publish"
  },
  "devDependencies": {
    "@changesets/changelog-github": "^0.7.0",
    "@changesets/cli": "^2.31.0",
    "knip": "^6.24.0",
    "markdownlint-cli2": "^0.23.0",
    "npm-run-all2": "^9.0.2",
    "prettier": "^3.9.4",
    "prettier-plugin-astro": "^0.14.1",
    "tsx": "^4.23.0",
    "turbo": "^2.10.2",
    "typescript": "^5.9.3"
  }
}
