{
  // Glob patterns to ignore
  "ignores": [
    "AGENTS.md",
    "packages/**/CHANGELOG.md",
    "CLAUDE.md",
    "MARKETING.md",
    "monorepo.md",
    "typegraph-spec.md",
    ".changeset/**",
    ".pnpm-store/**",
    // Local Claude worktrees are independent checkouts, not this tree's docs.
    ".claude/worktrees/**",
    "**/node_modules/**",
    // Git-ignored local scratch space (see .gitignore).
    "packages/*/tmp/**",
    "docs/design/**",
    // Stryker mutation-testing sandboxes copy the package tree.
    "**/.stryker-tmp/**",
    // Generated by API Extractor. Reformatting these files would make the
    // checked-in baseline disagree with the generator.
    "**/*.api.md",
    // Auto-generated by apps/docs/scripts/sync-changelog.mjs from the
    // upstream CHANGELOG.md; line-length and other rules are inherited from
    // the source which is already ignored above.
    "apps/docs/src/content/docs/changelog.md",
  ],
}
