{
  // Glob patterns to ignore
  "ignores": [
    "AGENTS.md",
    "packages/**/CHANGELOG.md",
    "CLAUDE.md",
    "MARKETING.md",
    "monorepo.md",
    "typegraph-spec.md",
    // Internal design / decision notes (ratified specs, spikes). Prose
    // working documents, not published docs — the published guides live
    // under apps/docs and are linted.
    "docs/design/**",
    ".changeset/**",
    ".pnpm-store/**",
    "**/node_modules/**",
    // Gitignored scratch directories (markdownlint doesn't read .gitignore).
    "**/tmp/**",
    // Scratch PR-draft notes kept at the repo root, never published.
    "PR_DRAFT_*.md",
    // Auto-generated by apps/docs/scripts/sync-changelog.mjs from the
    // upstream CHANGELOG.md; line-length and other rules are inherited from
    // the source which is already ignored above.
    "apps/docs/src/content/docs/changelog.md",
  ],
}
