{
  "name": "@nicia-ai/typegraph-benchmarks",
  "private": true,
  "type": "module",
  "scripts": {
    "prebench": "pnpm --filter @nicia-ai/typegraph build",
    "bench": "tsx src/main.ts",
    "preperf": "pnpm --filter @nicia-ai/typegraph build",
    "perf": "tsx src/main.ts",
    "preperf:check": "pnpm --filter @nicia-ai/typegraph build",
    "perf:check": "tsx src/main.ts --check",
    "preperf:postgres": "pnpm --filter @nicia-ai/typegraph build",
    "perf:postgres": "tsx src/main.ts --backend=postgres",
    "preperf:check:postgres": "pnpm --filter @nicia-ai/typegraph build",
    "perf:check:postgres": "tsx src/main.ts --check --backend=postgres",
    "preperf:file": "pnpm --filter @nicia-ai/typegraph build",
    "perf:file": "tsx src/main.ts --storage=file",
    "preperf:check:file": "pnpm --filter @nicia-ai/typegraph build",
    "perf:check:file": "tsx src/main.ts --check --storage=file",
    "prebench:compile": "pnpm --filter @nicia-ai/typegraph build",
    "bench:compile": "tsx src/compile-bench.ts",
    "prebench:compile:postgres": "pnpm --filter @nicia-ai/typegraph build",
    "bench:compile:postgres": "tsx src/compile-bench.ts --backend=postgres",
    "prebench:write": "pnpm --filter @nicia-ai/typegraph build",
    "bench:write": "tsx src/write-bench.ts",
    "prebench:write:file": "pnpm --filter @nicia-ai/typegraph build",
    "bench:write:file": "tsx src/write-bench.ts --storage=file",
    "prebench:write:postgres": "pnpm --filter @nicia-ai/typegraph build",
    "bench:write:postgres": "tsx src/write-bench.ts --backend=postgres",
    "prebench:vector": "pnpm --filter @nicia-ai/typegraph build",
    "bench:vector": "tsx src/vector-bench.ts",
    "prebench:vector:file": "pnpm --filter @nicia-ai/typegraph build",
    "bench:vector:file": "tsx src/vector-bench.ts --storage=file",
    "prebench:vector:postgres": "pnpm --filter @nicia-ai/typegraph build",
    "bench:vector:postgres": "tsx src/vector-bench.ts --backend=postgres",
    "prebench:maintenance": "pnpm --filter @nicia-ai/typegraph build",
    "bench:maintenance": "tsx src/maintenance-bench.ts",
    "prebench:maintenance:postgres": "pnpm --filter @nicia-ai/typegraph build",
    "bench:maintenance:postgres": "tsx src/maintenance-bench.ts --backend=postgres",
    "prebench:recorded-write": "pnpm --filter @nicia-ai/typegraph build",
    "bench:recorded-write": "tsx src/recorded-write-bench.ts",
    "prebench:recorded-write:postgres": "pnpm --filter @nicia-ai/typegraph build",
    "bench:recorded-write:postgres": "tsx src/recorded-write-bench.ts --postgres",
    "prebench:snb:doctor": "pnpm --filter @nicia-ai/typegraph build",
    "bench:snb:doctor": "tsx src/real/harness/doctor-cli.ts",
    "prebench:snb:smoke": "pnpm --filter @nicia-ai/typegraph build",
    "bench:snb:smoke": "tsx src/real/snb-short-reads.ts --profile=smoke",
    "prebench:snb:smoke:check": "pnpm --filter @nicia-ai/typegraph build",
    "bench:snb:smoke:check": "tsx src/real/snb-short-reads.ts --profile=smoke --check",
    "prebench:snb:sf1": "pnpm --filter @nicia-ai/typegraph build",
    "bench:snb:sf1": "tsx src/real/snb-short-reads.ts --profile=sf1",
    "bench:snb:sf1:ec2": "tsx src/real/ec2/run-sf1-ec2.ts launch",
    "bench:snb:sf1:ec2:collect": "tsx src/real/ec2/run-sf1-ec2.ts collect",
    "bench:snb:generate-smoke-fixture": "tsx src/real/dataset/generate-smoke-fixture.ts",
    "typecheck": "tsc --noEmit --skipLibCheck"
  },
  "dependencies": {
    "@ladybugdb/core": "^0.18.0",
    "@nicia-ai/typegraph": "workspace:*",
    "better-sqlite3": "^12.11.1",
    "drizzle-orm": "^0.45.2",
    "neo4j-driver": "^6.2.0",
    "pg": "^8.22.0",
    "postgres": "^3.4.9",
    "sqlite-vec": "^0.1.9",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^24.13.2",
    "@types/pg": "^8.20.0",
    "tsx": "^4.23.0",
    "typescript": "^5.9.3"
  }
}
