{
  "name": "@nicia-ai/typegraph",
  "version": "0.16.2",
  "description": "TypeScript-first embedded knowledge graph library with ontological reasoning",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./interchange": {
      "import": {
        "types": "./dist/interchange/index.d.ts",
        "default": "./dist/interchange/index.js"
      },
      "require": {
        "types": "./dist/interchange/index.d.cts",
        "default": "./dist/interchange/index.cjs"
      }
    },
    "./profiler": {
      "import": {
        "types": "./dist/profiler/index.d.ts",
        "default": "./dist/profiler/index.js"
      },
      "require": {
        "types": "./dist/profiler/index.d.cts",
        "default": "./dist/profiler/index.cjs"
      }
    },
    "./schema": {
      "import": {
        "types": "./dist/schema/index.d.ts",
        "default": "./dist/schema/index.js"
      },
      "require": {
        "types": "./dist/schema/index.d.cts",
        "default": "./dist/schema/index.cjs"
      }
    },
    "./indexes": {
      "import": {
        "types": "./dist/indexes/index.d.ts",
        "default": "./dist/indexes/index.js"
      },
      "require": {
        "types": "./dist/indexes/index.d.cts",
        "default": "./dist/indexes/index.cjs"
      }
    },
    "./sqlite": {
      "import": {
        "types": "./dist/backend/sqlite/index.d.ts",
        "default": "./dist/backend/sqlite/index.js"
      },
      "require": {
        "types": "./dist/backend/sqlite/index.d.cts",
        "default": "./dist/backend/sqlite/index.cjs"
      }
    },
    "./postgres": {
      "import": {
        "types": "./dist/backend/postgres/index.d.ts",
        "default": "./dist/backend/postgres/index.js"
      },
      "require": {
        "types": "./dist/backend/postgres/index.d.cts",
        "default": "./dist/backend/postgres/index.cjs"
      }
    },
    "./sqlite/local": {
      "import": {
        "types": "./dist/backend/sqlite/local.d.ts",
        "default": "./dist/backend/sqlite/local.js"
      },
      "require": {
        "types": "./dist/backend/sqlite/local.d.cts",
        "default": "./dist/backend/sqlite/local.cjs"
      }
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "sideEffects": false,
  "scripts": {
    "dev": "tsup --watch",
    "build": "tsup",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit --skipLibCheck",
    "test:types": "node --import tsx scripts/test-types.ts all",
    "test:types:inline": "node --import tsx scripts/test-types.ts inline",
    "test:types:declarations": "node --import tsx scripts/test-types.ts declarations",
    "test:types:consumer": "node --import tsx scripts/test-types.ts consumer",
    "pretest": "node --import tsx scripts/ensure-native-sqlite.ts",
    "test": "vitest run",
    "pretest:unit": "node --import tsx scripts/ensure-native-sqlite.ts",
    "test:unit": "vitest run",
    "pretest:property": "node --import tsx scripts/ensure-native-sqlite.ts",
    "test:property": "vitest run tests/property",
    "pretest:perf": "node --import tsx scripts/ensure-native-sqlite.ts",
    "test:perf": "pnpm --filter @nicia-ai/typegraph-benchmarks perf:check",
    "bench:perf": "pnpm --filter @nicia-ai/typegraph-benchmarks perf",
    "test:perf:postgres": "pnpm --filter @nicia-ai/typegraph-benchmarks perf:check:postgres",
    "bench:perf:postgres": "pnpm --filter @nicia-ai/typegraph-benchmarks perf:postgres",
    "test:postgres": "./scripts/test-postgres.sh",
    "test:coverage": "vitest run --coverage",
    "test:mutation": "stryker run"
  },
  "keywords": [
    "graph",
    "knowledge-graph",
    "typescript",
    "sqlite",
    "drizzle",
    "zod",
    "ontology",
    "semantic"
  ],
  "author": "Nicia AI, Inc.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/nicia-ai/typegraph.git",
    "directory": "packages/typegraph"
  },
  "bugs": {
    "url": "https://github.com/nicia-ai/typegraph/issues"
  },
  "homepage": "https://typegraph.dev",
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=22"
  },
  "peerDependencies": {
    "better-sqlite3": ">=9.0.0 <13.0.0",
    "drizzle-orm": ">=0.35.0 <1.0.0",
    "zod": "^4.0.0"
  },
  "peerDependenciesMeta": {
    "better-sqlite3": {
      "optional": true
    }
  },
  "dependencies": {
    "nanoid": "^5.1.7"
  },
  "devDependencies": {
    "@stryker-mutator/core": "^9.6.0",
    "@stryker-mutator/vitest-runner": "^9.6.0",
    "@typegraph/eslint-config": "workspace:*",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^24.12.0",
    "@types/pg": "^8.20.0",
    "@vitest/coverage-v8": "^4.1.2",
    "better-sqlite3": "^12.8.0",
    "drizzle-orm": "^0.45.2",
    "eslint": "^10.1.0",
    "fast-check": "^4.6.0",
    "pg": "^8.20.0",
    "sqlite-vec": "^0.1.8",
    "tsd": "^0.33.0",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3",
    "vitest": "^4.1.2",
    "zod": "^4.3.6"
  }
}
