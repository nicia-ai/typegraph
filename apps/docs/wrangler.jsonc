{
  "$schema": "https://json.schemastore.org/wrangler",
  "name": "typegraph-docs",
  "compatibility_date": "2026-01-01",
  "main": "./dist/_worker.js",
  "assets": {
    "directory": "./dist",
    "binding": "ASSETS",
  },
  "observability": {
    "enabled": true,
    "head_sampling_rate": 1,
  },
}
