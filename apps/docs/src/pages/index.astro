<style is:global>
  @reference "tailwindcss";

  /* Syntax highlighting for hand-marked code samples on the homepage.
     Global so the rules match spans inside `<code is:raw>`, which are
     inserted verbatim and don't carry Astro's scoped-style attribute.
     `hl-` prefix avoids clashing with Starlight's Shiki output. */
  .hl-keyword {
    @apply text-blue-400;
  }
  .hl-string {
    @apply text-amber-300;
  }
  .hl-function {
    @apply text-yellow-300;
  }
  .hl-comment {
    @apply text-green-500;
  }
  .hl-type {
    @apply text-cyan-400;
  }
</style>

<style>
  @reference "tailwindcss";

  /* CSS-only tabs: hide radios, toggle panels by `:checked` sibling. */
  .code-tabs > input[type="radio"] {
    position: absolute;
    opacity: 0;
    pointer-events: none;
  }

  .code-tab-labels label {
    @apply cursor-pointer shrink-0 rounded-md px-4 py-2.5 text-sm font-mono text-[#c8d1df] border border-[#3b3b3b] bg-[#242424] transition-colors whitespace-nowrap;
  }
  .code-tab-labels label:hover {
    color: white;
    border-color: color-mix(in srgb, var(--color-primary) 60%, #3b3b3b);
    background-color: #2b3240;
  }

  .code-panel {
    display: none;
  }

  /* Active panel + active label per radio. Order matters: inputs must
     precede the labels/panels they style for sibling selectors to work. */
  #ctab-basic:checked ~ .code-tab-panels .code-panel-basic,
  #ctab-hybrid:checked ~ .code-tab-panels .code-panel-hybrid,
  #ctab-evolve:checked ~ .code-tab-panels .code-panel-evolve,
  #ctab-temporal:checked ~ .code-tab-panels .code-panel-temporal {
    display: block;
  }
  #ctab-basic:checked ~ .code-tab-labels label[for="ctab-basic"],
  #ctab-hybrid:checked ~ .code-tab-labels label[for="ctab-hybrid"],
  #ctab-evolve:checked ~ .code-tab-labels label[for="ctab-evolve"],
  #ctab-temporal:checked ~ .code-tab-labels label[for="ctab-temporal"] {
    color: white;
    border-color: var(--color-primary);
    background-color: color-mix(in srgb, var(--color-primary) 22%, #242424);
    box-shadow: inset 0 0 0 1px
      color-mix(in srgb, var(--color-primary) 35%, transparent);
  }

  /* Keyboard focus ring on labels when the underlying radio is focused. */
  .code-tabs > input[type="radio"]:focus-visible + .code-tab-labels label,
  .code-tabs > input[type="radio"]:focus-visible ~ .code-tab-labels label {
    outline: none;
  }
  #ctab-basic:focus-visible ~ .code-tab-labels label[for="ctab-basic"],
  #ctab-hybrid:focus-visible ~ .code-tab-labels label[for="ctab-hybrid"],
  #ctab-evolve:focus-visible ~ .code-tab-labels label[for="ctab-evolve"],
  #ctab-temporal:focus-visible ~ .code-tab-labels label[for="ctab-temporal"] {
    outline: 2px solid var(--color-primary);
    outline-offset: 2px;
    border-radius: 6px;
  }
</style>
