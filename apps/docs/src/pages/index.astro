---
import package_ from "../../../../packages/typegraph/package.json";
import FeatureIcon from "../components/landing/FeatureIcon.astro";
import HeroIllustration from "../components/landing/HeroIllustration.astro";
import NewsletterSignup from "../components/landing/NewsletterSignup.astro";
import Layout from "../layouts/Landing.astro";

const version = package_.version;
---

<Layout title="TypeGraph - The Knowledge Graph for TypeScript">
  <main class="max-w-[1200px] mx-auto px-8">
    <section
      class="grid grid-cols-1 md:grid-cols-[1.2fr_1fr] gap-16 items-center py-24 md:py-32"
    >
      <div class="text-left">
        <a
          href="/changelog"
          class="inline-flex items-center gap-2 px-3 py-1 mb-6 rounded-full border border-primary/30 bg-primary/10 text-sm font-mono text-primary hover:bg-primary/15 hover:border-primary/50 transition-colors no-underline"
          aria-label={`Version ${version} - Bitemporal history. See changelog.`}
        >
          <span
            class="inline-block w-2 h-2 rounded-full bg-primary"
            aria-hidden="true"></span>
          v{version} · Bitemporal history
          <span class="opacity-70" aria-hidden="true">→</span>
        </a>
        <h1 class="text-5xl font-extrabold leading-[1.1] mb-6 tracking-tight">
          The Knowledge Graph for <span
            class="bg-linear-to-br from-primary to-accent bg-clip-text text-transparent"
            >TypeScript</span
          >
        </h1>
        <p class="text-xl text-text-muted mb-10 max-w-[500px]">
          Define your ontology with Zod. Query with a fluent builder. Extend it
          at runtime when your agents need more.
        </p>
        <div class="flex flex-wrap gap-4">
          <a
            href="/getting-started"
            class="inline-flex items-center justify-center px-6 py-3 rounded-lg text-white bg-primary font-semibold hover:bg-primary-dark hover:-translate-y-px transition-all duration-200"
            >Get Started</a
          >
          <a
            href="https://github.com/nicia-ai/typegraph"
            class="inline-flex items-center justify-center px-6 py-3 rounded-lg text-text-main border border-border bg-transparent font-semibold hover:border-primary hover:text-primary transition-all duration-200"
            >View on GitHub</a
          >
        </div>
      </div>
      <div class="flex justify-center items-center relative">
        <HeroIllustration />
      </div>
    </section>

    <section class="py-16 text-center">
      <h2 class="text-4xl font-extrabold mb-4">
        Define. Connect. Query. Evolve.
      </h2>
      <p class="text-xl text-text-muted mb-12">
        Your schema is your database. Your types are your queries.
      </p>

      <div class="code-tabs max-w-[900px] mx-auto text-left">
        <input
          type="radio"
          name="ctab"
          id="ctab-basic"
          checked
          aria-label="Basic example"
        />
        <input
          type="radio"
          name="ctab"
          id="ctab-hybrid"
          aria-label="Hybrid search example"
        />
        <input
          type="radio"
          name="ctab"
          id="ctab-evolve"
          aria-label="Runtime evolution example"
        />
        <input
          type="radio"
          name="ctab"
          id="ctab-temporal"
          aria-label="Bitemporal history example"
        />

        <div
          class="code-tab-labels flex gap-2 border border-b-0 border-[#333] bg-[#181818] rounded-t-xl p-2 overflow-x-auto"
          role="tablist"
        >
          <label for="ctab-basic">Basic</label>
          <label for="ctab-hybrid">Hybrid Search</label>
          <label for="ctab-evolve">Runtime Evolution</label>
          <label for="ctab-temporal">Bitemporal</label>
        </div>

        <div
          class="code-tab-panels bg-[#1e1e1e] border border-t-0 border-[#333] rounded-b-xl shadow-2xl overflow-hidden"
        >
          <div class="code-panel code-panel-basic p-6 overflow-x-auto">
            <pre
              class="m-0 font-mono text-sm leading-relaxed text-[#d4d4d4]"><code is:raw><span class="hl-keyword">import</span> { defineNode, defineEdge, defineGraph, createStore } <span class="hl-keyword">from</span> <span class="hl-string">"@nicia-ai/typegraph"</span>;
<span class="hl-keyword">import</span> { z } <span class="hl-keyword">from</span> <span class="hl-string">"zod"</span>;

<span class="hl-comment">// 1. Define your ontology</span>
<span class="hl-keyword">const</span> <span class="hl-type">Person</span> = defineNode(<span class="hl-string">"Person"</span>, {
  schema: z.object({ name: z.string(), role: z.string() })
});
<span class="hl-keyword">const</span> <span class="hl-type">Project</span> = defineNode(<span class="hl-string">"Project"</span>, {
  schema: z.object({ name: z.string(), status: z.string() })
});
<span class="hl-keyword">const</span> <span class="hl-type">worksOn</span> = defineEdge(<span class="hl-string">"worksOn"</span>);

<span class="hl-keyword">const</span> <span class="hl-type">graph</span> = defineGraph({
  id: <span class="hl-string">"my_app"</span>,
  nodes: { Person: { type: Person }, Project: { type: Project } },
  edges: { worksOn: { type: worksOn, from: [Person], to: [Project] } }
});

<span class="hl-comment">// 2. Query with full type safety</span>
<span class="hl-keyword">const</span> <span class="hl-type">results</span> = <span class="hl-keyword">await</span> store.query()
  .from(<span class="hl-string">"Person"</span>, <span class="hl-string">"p"</span>)
  .whereNode(<span class="hl-string">"p"</span>, p =&gt; p.role.eq(<span class="hl-string">"Engineer"</span>))
  .traverse(<span class="hl-string">"worksOn"</span>, <span class="hl-string">"e"</span>)
  .to(<span class="hl-string">"Project"</span>, <span class="hl-string">"proj"</span>)
  .select(ctx =&gt; ({ person: ctx.p.name, project: ctx.proj.name }))
  .execute();</code></pre>
          </div>

          <div class="code-panel code-panel-hybrid p-6 overflow-x-auto">
            <pre
              class="m-0 font-mono text-sm leading-relaxed text-[#d4d4d4]"><code is:raw><span class="hl-keyword">import</span> { defineNode, searchable, embedding } <span class="hl-keyword">from</span> <span class="hl-string">"@nicia-ai/typegraph"</span>;
<span class="hl-keyword">import</span> { z } <span class="hl-keyword">from</span> <span class="hl-string">"zod"</span>;

<span class="hl-comment">// 1. Declare semantic + fulltext fields right in the Zod schema</span>
<span class="hl-keyword">const</span> <span class="hl-type">Document</span> = defineNode(<span class="hl-string">"Document"</span>, {
  schema: z.object({
    title: searchable({ language: <span class="hl-string">"english"</span> }),
    body:  searchable({ language: <span class="hl-string">"english"</span> }),
    embedding: embedding(1536),
  })
});

<span class="hl-comment">// 2. Hybrid retrieval: BM25 fulltext + vector similarity, fused with RRF</span>
<span class="hl-keyword">const</span> <span class="hl-type">hits</span> = <span class="hl-keyword">await</span> store.search.hybrid(<span class="hl-string">"Document"</span>, {
  limit: 10,
  vector:   { fieldPath: <span class="hl-string">"embedding"</span>, queryEmbedding: <span class="hl-keyword">await</span> embed(q) },
  fulltext: { query: q },
});

<span class="hl-comment">// 3. Or compose fulltext into any graph traversal — authorised search,</span>
<span class="hl-comment">//    multi-tenant filters, anything you can already express in a query.</span>
<span class="hl-keyword">const</span> <span class="hl-type">scoped</span> = <span class="hl-keyword">await</span> store.query()
  .from(<span class="hl-string">"User"</span>, <span class="hl-string">"u"</span>).whereNode(<span class="hl-string">"u"</span>, u =&gt; u.id.eq(currentUserId))
  .traverse(<span class="hl-string">"canRead"</span>, <span class="hl-string">"e"</span>).to(<span class="hl-string">"Document"</span>, <span class="hl-string">"d"</span>)
  .whereNode(<span class="hl-string">"d"</span>, d =&gt; d.$fulltext.matches(query, 10))
  .select(ctx =&gt; ctx.d).execute();</code></pre>
          </div>

          <div class="code-panel code-panel-evolve p-6 overflow-x-auto">
            <pre
              class="m-0 font-mono text-sm leading-relaxed text-[#d4d4d4]"><code is:raw><span class="hl-keyword">import</span> { defineGraphExtension } <span class="hl-keyword">from</span> <span class="hl-string">"@nicia-ai/typegraph"</span>;

<span class="hl-comment">// 1. An agent proposes a typed kind from observed data.</span>
<span class="hl-keyword">const</span> <span class="hl-type">proposal</span> = defineGraphExtension({
  nodes: {
    Paper: {
      description: <span class="hl-string">"An academic paper inferred from the corpus"</span>,
      properties: {
        title: { type: <span class="hl-string">"string"</span>, minLength: 1 },
        doi:   { type: <span class="hl-string">"string"</span>, minLength: 1 },
        year:  { type: <span class="hl-string">"number"</span>, int: <span class="hl-keyword">true</span>, min: 1900, max: 2100 },
      },
      unique: [{ name: <span class="hl-string">"paper_doi_unique"</span>, fields: [<span class="hl-string">"doi"</span>] }],
    },
  },
});

<span class="hl-comment">// 2. Operator approves; commit atomically as a new schema version.</span>
<span class="hl-keyword">const</span> <span class="hl-type">evolved</span> = <span class="hl-keyword">await</span> store.evolve(proposal);

<span class="hl-comment">// 3. Read and write the new kind dynamically — no codegen, no redeploy.</span>
<span class="hl-keyword">const</span> <span class="hl-type">papers</span> = evolved.getNodeCollection(<span class="hl-string">"Paper"</span>)!;
<span class="hl-keyword">await</span> papers.create({
  title: <span class="hl-string">"Attention Is All You Need"</span>,
  doi:   <span class="hl-string">"10.5555/3295222.3295349"</span>,
  year:  2017,
});</code></pre>
          </div>

          <div class="code-panel code-panel-temporal p-6 overflow-x-auto">
            <pre
              class="m-0 font-mono text-sm leading-relaxed text-[#d4d4d4]"><code is:raw><span class="hl-keyword">import</span> { createStore, asRecordedInstant } <span class="hl-keyword">from</span> <span class="hl-string">"@nicia-ai/typegraph"</span>;

<span class="hl-comment">// 1. Turn on recorded/system-time capture for committed writes.</span>
<span class="hl-keyword">const</span> <span class="hl-type">store</span> = createStore(graph, backend, { history: <span class="hl-keyword">true</span> });

<span class="hl-comment">// 2. Capture a deterministic recorded-time anchor after an agent decides.</span>
<span class="hl-keyword">await</span> store.nodes.Decision.create({ answer: <span class="hl-string">"approve source A"</span> });
<span class="hl-keyword">const</span> <span class="hl-type">decisionTime</span> = <span class="hl-keyword">await</span> store.recordedNow();
<span class="hl-keyword">if</span> (decisionTime === <span class="hl-keyword">undefined</span>) <span class="hl-keyword">throw new</span> Error(<span class="hl-string">"no recorded history yet"</span>);

<span class="hl-comment">// 3. Later, replay the exact graph the agent saw.</span>
<span class="hl-keyword">const</span> <span class="hl-type">replay</span> = store.asOfRecorded(decisionTime);
<span class="hl-keyword">const</span> <span class="hl-type">sameAnswer</span> = <span class="hl-keyword">await</span> replay
  .query()
  .from(<span class="hl-string">"Decision"</span>, <span class="hl-string">"d"</span>)
  .select(ctx =&gt; ctx.d.answer)
  .first();

<span class="hl-comment">// Valid time and recorded time can be pinned independently.</span>
<span class="hl-keyword">const</span> <span class="hl-type">whatWeKnewThen</span> = store
  .asOf(<span class="hl-string">"2026-01-01T00:00:00.000Z"</span>)
  .asOfRecorded(asRecordedInstant(<span class="hl-string">"2026-02-01T00:00:00.000Z"</span>));</code></pre>
          </div>
        </div>
      </div>
    </section>

    <section class="py-24">
      <div class="text-center mb-14">
        <p
          class="text-sm font-mono uppercase tracking-[0.24em] text-primary mb-4"
        >
          The graph lifecycle
        </p>
        <h2 class="text-4xl font-extrabold mb-4">
          Stop stitching graph tools together.
        </h2>
        <p class="text-xl text-text-muted max-w-[760px] mx-auto">
          Keep schema, search, reasoning, merge, and history in one typed
          system.
        </p>
      </div>

      <div class="relative">
        <div class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-3 gap-5">
          <a
            href="/overview"
            class="group relative z-10 p-6 bg-bg-card rounded-lg border border-border no-underline hover:-translate-y-1 hover:border-primary transition-all duration-200 flex flex-col min-h-[260px] [&_svg]:mb-0"
          >
            <div class="flex items-center justify-between gap-3 mb-5">
              <span
                class="inline-flex items-center justify-center w-10 h-10 rounded-full bg-bg-main border border-border text-sm font-mono text-primary group-hover:border-primary transition-colors"
                >01</span
              >
              <FeatureIcon icon="code" />
            </div>
            <h3 class="text-xl font-bold text-text-main mb-3">Define</h3>
            <p class="text-text-muted leading-relaxed mb-6 grow">
              Zod schemas for compile time type safety and runtime validation.
            </p>
            <code
              class="inline-block self-start bg-primary/10 text-primary px-2 py-1 rounded text-xs font-mono"
              >defineGraph</code
            >
          </a>

          <a
            href="/semantic-search"
            class="group relative z-10 p-6 bg-bg-card rounded-lg border border-border no-underline hover:-translate-y-1 hover:border-primary transition-all duration-200 flex flex-col min-h-[260px] [&_svg]:mb-0"
          >
            <div class="flex items-center justify-between gap-3 mb-5">
              <span
                class="inline-flex items-center justify-center w-10 h-10 rounded-full bg-bg-main border border-border text-sm font-mono text-primary group-hover:border-primary transition-colors"
                >02</span
              >
              <FeatureIcon icon="search" />
            </div>
            <h3 class="text-xl font-bold text-text-main mb-3">Retrieve</h3>
            <p class="text-text-muted leading-relaxed mb-6 grow">
              Typed query builders plus BM25, vector, graph, and hybrid
              retrieval.
            </p>
            <code
              class="inline-block self-start bg-primary/10 text-primary px-2 py-1 rounded text-xs font-mono"
              >search.hybrid</code
            >
          </a>

          <a
            href="/graph-algorithms"
            class="group relative z-10 p-6 bg-bg-card rounded-lg border border-border no-underline hover:-translate-y-1 hover:border-primary transition-all duration-200 flex flex-col min-h-[260px] [&_svg]:mb-0"
          >
            <div class="flex items-center justify-between gap-3 mb-5">
              <span
                class="inline-flex items-center justify-center w-10 h-10 rounded-full bg-bg-main border border-border text-sm font-mono text-primary group-hover:border-primary transition-colors"
                >03</span
              >
              <FeatureIcon icon="tree" />
            </div>
            <h3 class="text-xl font-bold text-text-main mb-3">Reason</h3>
            <p class="text-text-muted leading-relaxed mb-6 grow">
              Ontology powered reasoning plus graph algorithms over the same
              graph.
            </p>
            <code
              class="inline-block self-start bg-primary/10 text-primary px-2 py-1 rounded text-xs font-mono"
              >store.algorithms</code
            >
          </a>

          <a
            href="/graph-extensions"
            class="group relative z-10 p-6 bg-bg-card rounded-lg border border-border no-underline hover:-translate-y-1 hover:border-primary transition-all duration-200 flex flex-col min-h-[260px] [&_svg]:mb-0"
          >
            <div class="flex items-center justify-between gap-3 mb-5">
              <span
                class="inline-flex items-center justify-center w-10 h-10 rounded-full bg-bg-main border border-border text-sm font-mono text-primary group-hover:border-primary transition-colors"
                >04</span
              >
              <FeatureIcon icon="sparkles" />
            </div>
            <h3 class="text-xl font-bold text-text-main mb-3">Evolve</h3>
            <p class="text-text-muted leading-relaxed mb-6 grow">
              Update schema at runtime, or have agents propose the change for
              review.
            </p>
            <code
              class="inline-block self-start bg-primary/10 text-primary px-2 py-1 rounded text-xs font-mono"
              >store.evolve</code
            >
          </a>

          <a
            href="/graph-merge"
            class="group relative z-10 p-6 bg-bg-card rounded-lg border border-border no-underline hover:-translate-y-1 hover:border-primary transition-all duration-200 flex flex-col min-h-[260px] [&_svg]:mb-0"
          >
            <div class="flex items-center justify-between gap-3 mb-5">
              <span
                class="inline-flex items-center justify-center w-10 h-10 rounded-full bg-bg-main border border-border text-sm font-mono text-primary group-hover:border-primary transition-colors"
                >05</span
              >
              <FeatureIcon icon="branch" />
            </div>
            <h3 class="text-xl font-bold text-text-main mb-3">Merge</h3>
            <p class="text-text-muted leading-relaxed mb-6 grow">
              Branch and merge safely with entity resolution, conflicts, and
              provenance.
            </p>
            <code
              class="inline-block self-start bg-primary/10 text-primary px-2 py-1 rounded text-xs font-mono"
              >merge</code
            >
          </a>

          <a
            href="/queries/temporal"
            class="group relative z-10 p-6 bg-bg-card rounded-lg border border-border no-underline hover:-translate-y-1 hover:border-primary transition-all duration-200 flex flex-col min-h-[260px] [&_svg]:mb-0"
          >
            <div class="flex items-center justify-between gap-3 mb-5">
              <span
                class="inline-flex items-center justify-center w-10 h-10 rounded-full bg-bg-main border border-border text-sm font-mono text-primary group-hover:border-primary transition-colors"
                >06</span
              >
              <FeatureIcon icon="shield" />
            </div>
            <h3 class="text-xl font-bold text-text-main mb-3">Replay</h3>
            <p class="text-text-muted leading-relaxed mb-6 grow">
              Valid time and recorded time show who knew what when.
            </p>
            <code
              class="inline-block self-start bg-primary/10 text-primary px-2 py-1 rounded text-xs font-mono"
              >asOfRecorded</code
            >
          </a>
        </div>
      </div>
    </section>

    <section class="pt-14 pb-20 bg-bg-card -mx-8 px-4 sm:px-8">
      <div class="max-w-[1200px] mx-auto">
        <div class="mb-8">
          <div>
            <p
              class="text-sm font-mono uppercase tracking-[0.24em] text-primary mb-4"
            >
              Example showcase
            </p>
            <h2 class="text-4xl font-extrabold mb-4">
              Complete workflows, not toy demos.
            </h2>
          </div>
        </div>

        <div class="grid grid-cols-1 lg:grid-cols-[1.15fr_0.85fr] gap-6">
          <a
            href="/examples/research-copilot"
            class="group bg-bg-main border border-border rounded-lg p-8 md:p-10 no-underline hover:-translate-y-1 hover:border-primary transition-all duration-200"
          >
            <h3 class="text-3xl font-extrabold text-text-main mb-4">
              Research Copilot
            </h3>
            <p
              class="text-lg text-text-muted leading-relaxed max-w-[720px] mb-8"
            >
              A literature-review assistant over landmark ML papers. It blends
              semantic retrieval, topic hierarchy expansion, citation-authority
              ranking, shortest-path lineage, and collaborator discovery in one
              SQLite graph.
            </p>
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-x-8 gap-y-5 mb-8">
              <div class="border-t border-border pt-4">
                <p class="font-mono text-xs text-primary mb-2">
                  semantic retrieval
                </p>
                <p class="text-sm text-text-muted">
                  Embedding fields rank papers against the query.
                </p>
              </div>
              <div class="border-t border-border pt-4">
                <p class="font-mono text-xs text-primary mb-2">
                  ontology expansion
                </p>
                <p class="text-sm text-text-muted">
                  Topic hierarchy traversal improves recall.
                </p>
              </div>
              <div class="border-t border-border pt-4">
                <p class="font-mono text-xs text-primary mb-2">
                  graph algorithms
                </p>
                <p class="text-sm text-text-muted">
                  Degree and shortest path explain why each paper matters.
                </p>
              </div>
              <div class="border-t border-border pt-4">
                <p class="font-mono text-xs text-primary mb-2">
                  typed traversal
                </p>
                <p class="text-sm text-text-muted">
                  The digest is assembled through the query builder.
                </p>
              </div>
            </div>
            <span
              class="inline-flex text-primary font-semibold transition-transform duration-200 group-hover:translate-x-1"
              >See the example →</span
            >
          </a>

          <div class="grid grid-cols-1 gap-4">
            <a
              href="/examples/fhir-graph-merge"
              class="group bg-bg-main border border-border rounded-lg p-6 no-underline hover:-translate-y-1 hover:border-primary transition-all duration-200"
            >
              <div class="flex items-center justify-between gap-4 mb-4">
                <h3 class="text-xl font-bold text-text-main">
                  FHIR Graph Merge
                </h3>
                <span
                  class="shrink-0 text-xs font-mono text-primary bg-primary/10 rounded-full px-3 py-1"
                  >Merge</span
                >
              </div>
              <p class="text-text-muted leading-relaxed mb-5">
                Two ingestion agents disagree on patient identity. Branches
                isolate writes; merge resolves duplicates, repoints clinical
                edges, and reports provenance.
              </p>
              <div class="flex flex-wrap gap-2 mb-5">
                <span
                  class="text-xs font-mono text-text-muted bg-bg-card border border-border rounded px-2 py-1"
                  >Branch stores</span
                >
                <span
                  class="text-xs font-mono text-text-muted bg-bg-card border border-border rounded px-2 py-1"
                  >Entity resolution</span
                >
                <span
                  class="text-xs font-mono text-text-muted bg-bg-card border border-border rounded px-2 py-1"
                  >Conflict report</span
                >
              </div>
              <span
                class="inline-flex text-primary font-semibold transition-transform duration-200 group-hover:translate-x-1"
                >See the example →</span
              >
            </a>

            <a
              href="/examples/agent-decision-replay"
              class="group bg-bg-main border border-border rounded-lg p-6 no-underline hover:-translate-y-1 hover:border-primary transition-all duration-200"
            >
              <div class="flex items-center justify-between gap-4 mb-4">
                <h3 class="text-xl font-bold text-text-main">
                  Agent Decision Replay
                </h3>
                <span
                  class="shrink-0 text-xs font-mono text-primary bg-primary/10 rounded-full px-3 py-1"
                  >Replay</span
                >
              </div>
              <p class="text-text-muted leading-relaxed mb-5">
                Save a recorded-time anchor when the agent decides, then rerun
                the same reasoning code against the exact graph it saw.
              </p>
              <div class="flex flex-wrap gap-2 mb-5">
                <span
                  class="text-xs font-mono text-text-muted bg-bg-card border border-border rounded px-2 py-1"
                  >Recorded time</span
                >
                <span
                  class="text-xs font-mono text-text-muted bg-bg-card border border-border rounded px-2 py-1"
                  >Agent audit</span
                >
                <span
                  class="text-xs font-mono text-text-muted bg-bg-card border border-border rounded px-2 py-1"
                  >Graph algorithms</span
                >
              </div>
              <span
                class="inline-flex text-primary font-semibold transition-transform duration-200 group-hover:translate-x-1"
                >See the example →</span
              >
            </a>

            <a
              href="/examples/breach-forensics"
              class="group bg-bg-main border border-border rounded-lg p-6 no-underline hover:-translate-y-1 hover:border-primary transition-all duration-200"
            >
              <div class="flex items-center justify-between gap-4 mb-4">
                <h3 class="text-xl font-bold text-text-main">
                  Breach Forensics
                </h3>
                <span
